{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Doku",
  "version": "0.1.0",
  "identifier": "com.soundnodes.doku",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Doku",
        "width": 1280,
        "height": 800,
        "minWidth": 560,
        "minHeight": 360,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "description": "Document Markdown",
        "role": "Editor"
      },
      {
        "ext": ["html", "htm"],
        "name": "HTML",
        "description": "Document HTML",
        "role": "Editor"
      }
    ]
  }
}
